# MongoDB Configuration
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/gigarmour

# JWT Secret (use a strong random string)
JWT_SECRET=your-super-secret-jwt-key-change-this

# Weather API (Tomorrow.io)
TOMORROW_API_KEY=your-tomorrow-io-api-key

# Razorpay Configuration (Optional - for payment processing)
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_ACCOUNT_NUMBER=your-razorpay-account-number

# Environment
NODE_ENV=production

# Port (Render sets PORT automatically)
PORT=5000

# Frontend URL (for CORS) - Set this to your Vercel frontend URL
FRONTEND_URL=https://gigarmour-frontend.vercel.app

# Email Configuration - Resend (works on local, Render, and Vercel)
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=your-resend-api-key

# Email sender address (use your verified domain or onboarding@resend.dev for testing)
# To verify a domain: https://resend.com/domains
EMAIL_FROM=onboarding@resend.dev

# Optional: Fallback Gmail credentials (for local development only)
# EMAIL=your-email@gmail.com
# EMAIL_PASSWORD=your-app-password